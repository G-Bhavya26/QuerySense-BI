# ============================================================
# QuerySense — Environment Variables
# ============================================================
# HOW TO USE:
#   1. Copy this file:  cp .env.example .env
#   2. Fill in your real API keys in the .env file
#   3. Never share or upload the .env file
# ============================================================

# REQUIRED — Get yours at: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# OPTIONAL — How many times to retry a broken SQL query (default: 3)
MAX_RETRIES=3

# OPTIONAL — How unusual a value must be to flag as anomaly (default: 2.5)
ANOMALY_THRESHOLD=2.5
