# ============================================================
# QuerySense BI — .gitignore
# ============================================================

# ── Secrets — NEVER upload these ──────────────────────────
.env
*.pem
*.key

# ── Python auto-generated files ───────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
dist/
build/
*.egg

# ── Virtual environments ──────────────────────────────────
venv/
.venv/
env/
ENV/

# ── Testing & coverage ────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
coverage.xml

# ── Generated output files ────────────────────────────────
# PDFs generated by the app at runtime
*.pdf
# Temp audio files from voice input (if ever re-added)
*.wav
*.mp3

# ── Local data files ──────────────────────────────────────
# Don't upload personal test datasets
*.csv
*.xlsx
*.xls
*.json
*.parquet
*.tsv

# ── Streamlit ─────────────────────────────────────────────
.streamlit/secrets.toml

# ── IDEs & editors ────────────────────────────────────────
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln

# ── OS junk files ─────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Logs ──────────────────────────────────────────────────
*.log
logs/
